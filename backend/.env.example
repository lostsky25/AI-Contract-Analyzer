# Copy to backend/.env (never commit backend/.env):
#   cp backend/.env.example backend/.env
#
# Used by: local uvicorn (cwd backend/) and Docker Compose (env_file on api service).
# In Docker, compose overrides DATABASE_URL, UPLOAD_DIR, CHROMA_DB_DIR, TESSERACT_CMD.

ENV=development

# --- Storage (local defaults; Docker overrides paths via compose) ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
CHROMA_DB_DIR=./chroma_db
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# --- PostgreSQL ---
# Local:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_contract_analyzer
# Docker (set in compose; uncomment only if running api container without compose overrides):
# DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_contract_analyzer

# --- OpenRouter (required for analyze / Q&A / optional legal web search) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_OCR_MODEL=nvidia/nemotron-nano-12b-v2-vl
OPENROUTER_MODEL_OCR_VLM=nvidia/nemotron-nano-12b-v2-vl
OPENROUTER_MODEL_RISK=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL_KEY_TERMS=google/gemma-4-31b-it:free
OPENROUTER_MODEL_QA=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL_LEGAL_RESEARCH=openrouter/owl-alpha
OPENROUTER_MODEL_FALLBACK=deepseek/deepseek-v4-flash:free

# --- OCR (local Windows — set paths; Docker uses image defaults) ---
TESSERACT_CMD=
POPPLER_PATH=
OCR_PROVIDER=hybrid
OCR_USE_VLM=true
OCR_VLM_MAX_PAGES=20
OCR_VLM_DPI=160
OCR_VLM_TIMEOUT_SECONDS=120
OCR_MIN_TEXT_CHARS_PER_PAGE=50

# --- Legal web search (global default; UI can disable per analyze request) ---
LEGAL_WEB_SEARCH_ENABLED=true
LEGAL_SEARCH_PROVIDER=openrouter_web_search
LEGAL_ALLOWED_DOMAINS=consultant.ru,garant.ru,pravo.gov.ru
LEGAL_SEARCH_MAX_RESULTS=3
LEGAL_SEARCH_CONTEXT_SIZE=low

# --- Auth ---
JWT_SECRET_KEY=demo-only-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
