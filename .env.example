# Copy to .env in project root: cp .env.example .env

# App
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=20

# PostgreSQL (host "db" is the Docker service name)
DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_contract_analyzer

# ChromaDB / embeddings
CHROMA_DB_DIR=/app/chroma_db
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# OpenRouter (optional for /api/analyze)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b
OPENROUTER_OCR_MODEL=nvidia/nemotron-nano-12b-v2-vl

# OCR (Linux paths inside Docker image)
TESSERACT_CMD=/usr/bin/tesseract
POPPLER_PATH=
