# Copy to backend/.env (never commit backend/.env)

ENV=development

# --- Storage ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
CHROMA_DB_DIR=./chroma_db
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# text-embedding-3-large is a remote OpenAI-compatible embedding model and is not
# supported by EMBEDDING_MODEL_NAME unless a remote embeddings provider is implemented.

# --- PostgreSQL ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_contract_analyzer
# Docker:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_contract_analyzer

# --- Primary AI provider: BotHub ---
# Used for text LLM, Vision OCR and LegalResearch.
BOTHUB_API_KEY=
BOTHUB_API_BASE_URL=https://openai.bothub.chat/v1

# --- Text LLM models via BotHub ---
LLM_PROVIDER=bothub
LLM_MODEL_RISK=
LLM_MODEL_KEY_TERMS=
LLM_MODEL_QA=
LLM_MODEL_FALLBACK=
LLM_INCLUDE_USAGE=false
LLM_TIMEOUT_SECONDS=60

# --- Vision OCR via BotHub ---
VISION_PROVIDER=bothub
VISION_MODEL_OCR=
VISION_TIMEOUT_SECONDS=120
VISION_INCLUDE_USAGE=false

# --- OCR local fallback ---
TESSERACT_CMD=
OCR_TESSERACT_LANG=rus+eng
POPPLER_PATH=
OCR_PROVIDER=hybrid
OCR_USE_VLM=true
OCR_DEBUG=false
OCR_VLM_MAX_PAGES=20
OCR_VLM_DPI=220
OCR_VLM_TIMEOUT_SECONDS=120
OCR_MIN_TEXT_CHARS_PER_PAGE=50

# --- Legal Research via BotHub ---
LEGAL_WEB_SEARCH_ENABLED=true
LEGAL_RESEARCH_PROVIDER=bothub_sonar
LEGAL_RESEARCH_MODEL=
LEGAL_RESEARCH_ALLOWED_DOMAINS=consultant.ru,garant.ru,pravo.gov.ru
LEGAL_RESEARCH_ALLOW_MODEL_REPORTED_SOURCES=true
LEGAL_RESEARCH_DEBUG=false
LEGAL_SEARCH_MAX_RESULTS=3
LEGAL_SEARCH_CONTEXT_SIZE=low
#LEGAL_CONTEXT_FOR_RISK_ENABLED=false

# --- OpenRouter legacy fallback ---
# Only needed if you explicitly switch provider to OpenRouter legacy mode.
OPENROUTER_API_KEY=
OPENROUTER_MODEL_RISK=
OPENROUTER_MODEL_KEY_TERMS=
OPENROUTER_MODEL_QA=
OPENROUTER_MODEL_FALLBACK=
OPENROUTER_MODEL_LEGAL_RESEARCH=
OPENROUTER_MODEL_OCR_VLM=
OPENROUTER_OCR_MODEL=

# --- Auth ---
JWT_SECRET_KEY=demo-only-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
