# Example environment variables for backend
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b
OPENROUTER_OCR_MODEL=nvidia/nemotron-nano-12b-v2-vl
CHROMA_DB_DIR=./chroma_db
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# Local run:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_contract_analyzer
# Docker Compose (use root .env instead):
# DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_contract_analyzer
TESSERACT_CMD=
POPPLER_PATH=
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
