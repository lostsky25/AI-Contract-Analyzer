# Copy to .env in project root: cp .env.example .env

# App
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=20

# PostgreSQL (host "db" is the Docker service name)
DATABASE_URL=postgresql://postgres:postgres@db:5432/ai_contract_analyzer

# ChromaDB / embeddings
CHROMA_DB_DIR=/app/chroma_db
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# OpenRouter (optional for /api/analyze)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b
OPENROUTER_OCR_MODEL=nvidia/nemotron-nano-12b-v2-vl
OPENROUTER_MODEL_RISK=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL_KEY_TERMS=google/gemma-4-31b-it:free
OPENROUTER_MODEL_QA=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL_LEGAL_RESEARCH=openrouter/owl-alpha
OPENROUTER_MODEL_FALLBACK=deepseek/deepseek-v4-flash:free

# OCR (Linux paths inside Docker image)
TESSERACT_CMD=/usr/bin/tesseract
POPPLER_PATH=

# Agent workflow and legal search
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LEGAL_WEB_SEARCH_ENABLED=true
LEGAL_SEARCH_PROVIDER=openrouter_web_search
LEGAL_ALLOWED_DOMAINS=consultant.ru,garant.ru,pravo.gov.ru
LEGAL_SEARCH_MAX_RESULTS=5
LEGAL_SEARCH_CONTEXT_SIZE=medium
